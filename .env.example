NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GROQ_API_KEY=your-groq-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_your_api_key_here

# Error monitoring (Sentry — https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Product analytics (PostHog — https://posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Cron job protection secret (generate a strong random string)
# Set the same value in Vercel → Settings → Environment Variables
# Vercel will send: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your-cron-secret-here

# Billing runtime
BILLING_DEFAULT_GATEWAY=stripe
BILLING_WEBHOOK_SECRET=your-manual-webhook-secret

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Cakto
CAKTO_API_URL=https://api.cakto.com.br
CAKTO_CLIENT_ID=your-cakto-client-id
CAKTO_CLIENT_SECRET=your-cakto-client-secret
CAKTO_WEBHOOK_SECRET=your-cakto-webhook-secret
CAKTO_CONTEXT_SIGNING_SECRET=your-cakto-context-signing-secret
CAKTO_CHECKOUT_BASE_URL=https://pay.cakto.com.br
# Option A: mapping JSON (recommended)
CAKTO_CHECKOUT_MAP_JSON={"pf":{"1":{"pix":"a8BcHrY","card":"a8BcHrY"}}}
